{
  "$schema": "./house_style.schema.json",
  "version": "1.0.0",
  "name": "LynAI Mines / GeoVision Institutional",
  "owner": "Xuan-Ce / LynAI Mines",
  "description": "Single source of truth for all visual tokens. Imported by docx producer, chart renderer, and Critic-B during scoring.",

  "palette": {
    "primary_navy":   "0D1F3C",
    "accent_gold":    "C9A84C",
    "support_steel":  "5B7C99",
    "support_olive":  "A89060",
    "support_slate":  "3E5871",
    "neutral_text":   "1A1A1A",
    "neutral_caption":"555555",
    "neutral_rule":   "CCCCCC",
    "neutral_bgalt":  "FAFAFA",
    "alert_red":      "B22222",
    "white":          "FFFFFF"
  },

  "typography": {
    "body_serif":   "Georgia",
    "label_sans":   "Arial",
    "cn_serif":     "Source Han Serif SC",
    "cn_sans":      "Source Han Sans SC",
    "fallback_serif": "DejaVu Serif",
    "fallback_sans":  "DejaVu Sans"
  },

  "size_half_pts": {
    "_comment": "docx-js uses half-points: 21 = 10.5pt",
    "cover_title":    56,
    "cover_subtitle": 28,
    "cover_meta":     18,
    "h1":             32,
    "h2":             26,
    "h3":             22,
    "body":           21,
    "lead":           22,
    "caption":        17,
    "footnote":       16,
    "table_header":   19,
    "table_body":     19
  },

  "size_pt_chart": {
    "_comment": "Real points for matplotlib chart elements",
    "chart_title":    10,
    "chart_subtitle": 9,
    "axis_label":     9,
    "tick_label":     8,
    "annotation":     8,
    "source_line":    7,
    "legend":         8
  },

  "page": {
    "_comment": "A4 in DXA (1440 DXA = 1 inch). 25mm = 1417 DXA, 22mm = 1247 DXA",
    "width":  11906,
    "height": 16838,
    "margin": {
      "top":    1417,
      "right":  1247,
      "bottom": 1417,
      "left":   1247
    },
    "header_distance": 680,
    "footer_distance": 680
  },

  "image_dims_emu": {
    "_comment": "EMU (English Metric Units): 914400 = 1 inch. Content width on A4 = 166mm = 5981856 EMU.",
    "content_width_cx": 5981856,
    "half_width_cx":    2949576,
    "third_width_cx":   1990592
  },

  "spacing_dxa": {
    "_comment": "DXA twentieths-of-point: 20 DXA = 1pt. 240 DXA = 12pt.",
    "h1_before":   360,
    "h1_after":    160,
    "h2_before":   280,
    "h2_after":    120,
    "h3_before":   200,
    "h3_after":    80,
    "body_before": 0,
    "body_after":  120,
    "line_height": 264
  },

  "table": {
    "border_color":     "0D1F3C",
    "border_size":      8,
    "alt_row_shade":    "FAFAFA",
    "header_fill":      "0D1F3C",
    "header_text":      "FFFFFF",
    "cell_margin": {
      "top":    80,
      "bottom": 80,
      "left":   120,
      "right":  120
    }
  },

  "chart": {
    "dpi":              300,
    "width_px":         1800,
    "default_height_px": 1100,
    "background":       "FFFFFF",
    "series_palette": [
      "0D1F3C",
      "C9A84C",
      "5B7C99",
      "A89060",
      "3E5871"
    ],
    "sequential_ramp": [
      "0D1F3C",
      "3E5871",
      "5B7C99",
      "8FA5B8",
      "C2CFDB"
    ],
    "negative_color":   "B22222",
    "positive_color":   "0D1F3C",
    "gridline_color":   "EEEEEE",
    "axis_color":       "555555"
  },

  "page_furniture": {
    "header_left":  "{report_short_title}",
    "header_right": "{date_dd_mmm_yyyy}",
    "footer_left":  "GeoVision AI Mining | LynAI Mines",
    "footer_right": "p. {PAGE} of {NUMPAGES}",
    "rule_color":   "0D1F3C",
    "rule_pt":      0.75
  },

  "cover": {
    "gold_rule_width_mm": 50,
    "gold_rule_height_pt": 4,
    "top_margin_extra_mm": 60,
    "wordmark_text": "LYNAI MINES",
    "company_legal": "GeoVision AI Mining Pty Ltd | ACN 687 204 799",
    "confidential_note": "Confidential — for intended recipient only"
  }
}
